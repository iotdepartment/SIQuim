<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SIQuim</title>

    <!-- TailwindCSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Fuente Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>
<body class="flex min-h-screen flex-col bg-gray-50">

    <!-- Navbar -->
    <header>
        <nav class="border-b border-gray-200 bg-white">
            <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
                <div class="flex h-16 justify-between">
                    <!-- Logo -->
                    <div class="flex flex-shrink-0 items-center">
                        <a href="/" class="text-xl font-bold text-blue-600">SIQuim</a>
                    </div>

                    <!-- Links -->
                    <div class="hidden sm:flex sm:space-x-8">
                        <a href="/" class="flex items-center text-gray-700 hover:text-blue-600">Home</a>
                        <a href="/Home/Privacy" class="flex items-center text-gray-700 hover:text-blue-600">Privacy</a>
                        <a href="/Inventario/Materiales" class="flex items-center text-gray-700 hover:text-blue-600">Materiales</a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <!-- Contenido principal -->
    <main role="main" class="container mx-auto flex-grow px-4 py-6">
        @RenderBody()
    </main>

    <!-- Footer fijo abajo -->
    <footer class="border-t bg-white text-gray-500">
        <div class="mx-auto max-w-7xl px-4 py-4">
            &copy; 2026 - SIQuim - <a asp-area="" asp-controller="Home" asp-action="Privacy" class="hover:text-blue-600">Privacy</a>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>