@{
    ViewData["Title"] = "Control de Inventarios";
}
<!-- Contenedor principal -->
<div class="container mt-4">

    <!-- Grid de dos columnas -->
    <div class="row">
        <!-- Sección escaneo de empleado -->
        <div class="col-md-6 mb-4">
            <!-- Card título -->
            <div class="card rounded-pill mb-3 border-0 shadow-sm">
                <div class="card-body text-center">
                    <h2 class="h5 fw-bold mb-0">👷 Escaneo de empleado</h2>
                </div>
            </div>
            <!-- Card contenido -->
            <div class="card rounded-4 border-0 shadow-sm">
                <div class="card-body">
                    <label for="empleadoScan" class="form-label">Número de empleado</label>
                    <input id="empleadoScan" type="text" class="form-control w-75"
                           placeholder="Escanea tu número de empleado" autofocus />
                </div>
            </div>
        </div>

        <!-- Sección información del empleado -->
        <div class="col-md-6 mb-4">
            <!-- Card título -->
            <div id="empleadotitle" class="card rounded-pill d-none mb-3 border-0 shadow-sm">
                <div class="card-body text-center">
                    <h2 class="h5 fw-bold mb-0">📋 Información del empleado</h2>
                </div>
            </div>
            <!-- Card contenido -->
            <div id="empleadoInfo" class="card rounded-4 d-none border-0 shadow-sm">
                <div class="card-body d-flex align-items-center gap-3">
                    <img id="empleadoFoto" src="/images/user.png" alt="Foto TM"
                         class="rounded-circle border" style="width:80px;height:80px;object-fit:cover;" />
                    <div>
                        <p class="fw-bold mb-1" id="empleadoNombre">Nombre del empleado</p>
                        <p class="mb-0">Número: <span id="empleadoNumero"></span></p>
                        <p class="mb-0">Área: <span id="empleadoArea"></span></p>
                        <p class="mb-0">Categoría: <span id="empleadoCategoria"></span></p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Card: Kanban y materiales -->
    <div id="kanbanSection" class="card d-none rounded-4 mt-4 border-0 shadow-sm">
        <div class="card-body">
            <h2 class="h5 fw-bold mb-3">📦 Materiales escaneados</h2>
            <p class="text-muted">Escanea Kanban. Cuando termines, escanea el código <strong>FIN</strong>.</p>
            <input id="kanbanScan" type="text" class="form-control w-25 mb-3"
                   placeholder="Escanea código Kanban" />

            <!-- Tabla productos -->
            <div id="productosSection" class="d-none">
                <table class="table-bordered table-striped rounded-4 table">
                    <thead class="table-light">
                        <tr>
                            <th>Cantidad</th>
                            <th>Imagen</th>
                            <th>Descripción</th>
                            <th>Kanban</th>
                            <th>Part Number</th>
                            <th>UOM</th>
                            <th>StdPack</th>
                        </tr>
                    </thead>
                    <tbody id="productosBody"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal receptor -->
<div class="modal fade" id="modalReceptor" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" id="modalContent">
            <div class="modal-header">
                <h5 class="modal-title">Escanea No. de Empleado</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <!-- Input receptor -->
                <input id="empleadoReceptorInput" type="text" class="form-control mb-3"
                       placeholder="No. de Empleado" />

                <!-- Info receptor -->
                <div id="empleadoReceptorInfo" class="card d-none mb-3">
                    <div class="card-body d-flex align-items-center gap-3">
                        <img src="/images/user.png" alt="Foto receptor"
                             class="rounded-circle border" style="width:64px;height:64px;object-fit:cover;" />
                        <div>
                            <p class="fw-bold mb-1" id="receptorNombre"></p>
                            <p class="mb-0">Número: <span id="receptorNumero"></span></p>
                            <p class="mb-0">Área: <span id="receptorArea"></span></p>
                            <p class="mb-0">Categoría: <span id="receptorCategoria"></span></p>
                        </div>
                    </div>
                </div>

                <!-- Input confirmación -->
                <input id="confirmacionInput" type="text" class="form-control d-none"
                       placeholder="Escribe OK para confirmar o CANCELAR para reintentar" />
            </div>
        </div>
    </div>
</div>
@section Scripts {

    <script>
        // Estado del flujo
        let flujoEstado = "inicio";
        let empleadoDespacha = null;
        let empleadoRecibe = null;
        let productos = {};

        // Instancia modal Bootstrap
        const modalReceptor = new bootstrap.Modal(document.getElementById("modalReceptor"));

        // Cuando el modal se muestra, hacer focus en el input
        document.getElementById("modalReceptor").addEventListener("shown.bs.modal", () => {
            document.getElementById("empleadoReceptorInput").focus();
        });

        // Función genérica para mostrar alertas
        function mostrarAlerta(tipo, titulo, texto) {
            Swal.fire({
                toast: true,
                position: 'top-end',
                icon: tipo,              // "success", "error", "warning", "info"
                title: titulo,
                text: texto,
                showConfirmButton: false,
                timer: 3000,             // Se cierra solo en 3 segundos
                timerProgressBar: true,
                background: tipo === 'success' ? '#4CAF50' : '#f44336',
                color: '#fff'
            });
        }

        // Renderizar tabla de productos
        function renderTabla() {
            const body = document.getElementById("productosBody");
            body.innerHTML = Object.values(productos).map(p => {
                const imgPath = p.imageUrl ? `/images/materiales/${p.imageUrl}` : `/images/materiales/default.png`;
                return `
                    <tr>
                        <td>x${p.count}</td>
                        <td><img src="${imgPath}" class="img-thumbnail" style="width:48px;height:48px;object-fit:cover;" /></td>
                        <td>${p.description}</td>
                        <td>${p.kanban}</td>
                        <td>${p.partNumber}</td>
                        <td>${p.uom}</td>
                        <td>${p.stdPack}</td>
                    </tr>`;
            }).join("");
        }

        // Buscar empleado
        async function buscarEmpleado(numero) {
            const r = await fetch(`/Inventario/BuscarEmpleado?numeroDeEmpleado=${numero}`);
            return r.json();
        }

        // Buscar material
        async function buscarMaterial(kanban) {
            const r = await fetch(`/Inventario/GetMaterialByKanban?kanban=${kanban}`);
            return r.json();
        }

        // Registrar pedido
        async function registrarPedido() {
            const materiales = Object.values(productos).map(p => ({ materialId: p.id, qty: p.count }));
            const pedidoDto = { responsableEntrega: empleadoDespacha, responsableReciba: empleadoRecibe, materiales };

            const r = await fetch("/Inventario/RegistrarPedido", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(pedidoDto)
            });
            return r.json();
        }

        // Escaneo de empleado inicial
        document.getElementById("empleadoScan").addEventListener("keyup", async e => {
            if (e.key === "Enter") {
                const code = e.target.value.trim();
                if (!code) return;

                const data = await buscarEmpleado(code);
                if (data.success) {
                    empleadoDespacha = data.numero;
                    flujoEstado = "escaneoKanban";

                    document.getElementById("empleadoNombre").textContent = data.nombre;
                    document.getElementById("empleadoNumero").textContent = data.numero;
                    document.getElementById("empleadoArea").textContent = data.area;
                    document.getElementById("empleadoCategoria").textContent = data.categoria;
                    document.getElementById("empleadoInfo").classList.remove("d-none");
                    document.getElementById("empleadotitle").classList.remove("d-none");

                    document.getElementById("kanbanSection").classList.remove("d-none");
                    document.getElementById("productosSection").classList.remove("d-none");
                    document.getElementById("kanbanScan").focus();
                } else {
                    mostrarAlerta("error", "Empleado no encontrado", data.error || "Verifica el número escaneado");
                }

                e.target.value = "";
            }
        });

        // Escaneo de Kanban o cierre
        document.getElementById("kanbanScan").addEventListener("keyup", async e => {
            if (e.key === "Enter") {
                const code = e.target.value.trim().toUpperCase();
                if (!code) return;

                if (code === "FIN") {
                    if (Object.keys(productos).length > 0) {
                        modalReceptor.show();
                        document.getElementById("empleadoReceptorInput").focus();
                    } else {
                        mostrarAlerta("error", "Acción inválida", "Debes registrar al menos un material antes de finalizar.");
                    }
                } else {
                    const data = await buscarMaterial(code);
                    if (data.success) {
                        const material = data.material;
                        const key = material.kanban.trim().toUpperCase();
                        productos[key] ? productos[key].count++ : productos[key] = { ...material, count: 1 };
                        renderTabla();
                    } else {
                        mostrarAlerta("error", "Material no encontrado", "Verifica el código escaneado");
                    }
                }

                e.target.value = "";
            }
        });

        // Escaneo de empleado receptor
        document.getElementById("empleadoReceptorInput").addEventListener("keyup", async e => {
            if (e.key !== "Enter") return;
            const code = e.target.value.trim();
            if (!code) return;

            const data = await buscarEmpleado(code);
            if (data.success) {
                empleadoRecibe = data.numero;
                flujoEstado = "confirmacion";

                document.getElementById("receptorNombre").textContent = data.nombre;
                document.getElementById("receptorNumero").textContent = data.numero;
                document.getElementById("receptorArea").textContent = data.area;
                document.getElementById("receptorCategoria").textContent = data.categoria;
                document.getElementById("empleadoReceptorInfo").classList.remove("d-none");

                document.getElementById("confirmacionInput").classList.remove("d-none");
                document.getElementById("confirmacionInput").focus();
            } else {
                mostrarAlerta("error", "Empleado no encontrado", data.error || "Verifica el número escaneado");

                document.getElementById("empleadoReceptorInfo").classList.add("d-none");
                document.getElementById("confirmacionInput").classList.add("d-none");
                document.getElementById("empleadoReceptorInput").focus();
            }

            e.target.value = "";
        });

        // Confirmación OK / CANCELAR
        document.getElementById("confirmacionInput").addEventListener("keyup", async e => {
            if (e.key !== "Enter") return;
            const decision = e.target.value.trim().toUpperCase();
            e.target.value = "";

            if (decision === "OK") {
                const result = await registrarPedido();
                if (result.success) {
                    localStorage.setItem("registroSuccess", "true");
                    location.reload();
                } else {
                    mostrarAlerta("error", "Error al registrar", result.error);
                }
                modalReceptor.hide();
            } else if (decision === "CANCELAR") {
                document.getElementById("empleadoReceptorInfo").classList.add("d-none");
                document.getElementById("confirmacionInput").classList.add("d-none");
                document.getElementById("empleadoReceptorInput").focus();
            } else {
                mostrarAlerta("error", "Entrada inválida", "Escribe OK para confirmar o CANCELAR para reintentar");
            }
        });

        // Toast de éxito al cargar
        window.addEventListener("load", () => {
            if (localStorage.getItem("registroSuccess") === "true") {
                localStorage.removeItem("registroSuccess");
                mostrarAlerta("success", "Pedido registrado correctamente", "");
            }
        });
    </script>

}