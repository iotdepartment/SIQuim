@{
    ViewData["Title"] = "Control de Inventarios";
}

<script src="https://cdn.tailwindcss.com"></script>

<div class="container mx-auto mt-10 max-w-6xl rounded-lg bg-white p-6 shadow-lg">
    <h1 class="mb-6 text-2xl font-bold text-gray-800">Sistema de Control de Inventarios</h1>

    <!-- Input para número de empleado -->
    <div class="mb-6">
        <label for="empleadoScan" class="mb-2 block font-semibold text-gray-700">Número de empleado</label>
        <input id="empleadoScan" type="text"
               class="w-full rounded-lg border border-gray-300 px-4 py-2 focus:ring-2 focus:ring-blue-500"
               placeholder="Escanea tu número de empleado" autofocus />
    </div>

    <!-- Info empleado -->
    <div id="empleadoInfo" class="mb-6 hidden rounded-lg border bg-gray-50 p-4">
        <div class="flex items-center gap-4">
            <img id="empleadoFoto" src="/images/user.png" alt="Foto TM"
                 class="h-20 w-20 rounded-full border object-cover" />
            <div>
                <p class="text-lg font-semibold text-gray-800">
                    <span id="empleadoNombre"></span>
                </p>
                <p class="text-gray-600">Empleado: <span id="empleadoNumero"></span></p>
                <p class="text-gray-600">Área: <span id="empleadoArea"></span></p>
                <p class="text-gray-600">Categoría: <span id="empleadoCategoria"></span></p>
            </div>
        </div>
    </div>

    <!-- Input para Kanban -->
    <div id="kanbanSection" class="mb-6 hidden">
        <label for="kanbanScan" class="mb-2 block font-semibold text-gray-700">Escanea Kanban. Cuando termines de escanear escanea el codigo FIN.</label>
        <input id="kanbanScan" type="text"
               class="w-full rounded-lg border border-gray-300 px-4 py-2 focus:ring-2 focus:ring-green-500"
               placeholder="Escanea código Kanban" />
    </div>

    <!-- Tabla de productos escaneados -->
    <div id="productosSection" class="hidden">
        <table class="min-w-full border border-gray-300 text-left text-sm">
            <thead class="bg-gray-100">
                <tr>
                    <th class="border px-4 py-2">Cantidad</th>
                    <th class="border px-4 py-2">Imagen</th>
                    <th class="border px-4 py-2">Descripción</th>
                    <th class="border px-4 py-2">Kanban</th>
                    <th class="border px-4 py-2">Part Number</th>
                    <th class="border px-4 py-2">UOM</th>
                    <th class="border px-4 py-2">StdPack</th>
                </tr>
            </thead>
            <tbody id="productosBody"></tbody>
        </table>
    </div>

    <!-- Modal receptor -->
    <div id="modalReceptor"
         class="fixed inset-0 flex hidden items-center justify-center bg-gray-900 bg-opacity-50">
        <div id="modalContent"
             class="w-96 scale-75 transform rounded-lg bg-white p-6 opacity-0 shadow-lg transition-opacity transition-transform duration-300 ease-out">
            <h2 class="mb-4 text-lg font-bold">Escanea empleado receptor</h2>
            <input id="empleadoReceptorInput" type="text"
                   class="w-full rounded-lg border border-gray-300 px-4 py-2 focus:ring-2 focus:ring-blue-500"
                   placeholder="Escanea número de empleado receptor" autofocus />
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        let flujoEstado = "inicio";
        let empleadoDespacha = null;
        let empleadoRecibe = null;
        let productos = {};

        // Animación zoom in para modal receptor
        function mostrarModalReceptor() {
            const modal = document.getElementById("modalReceptor");
            const content = document.getElementById("modalContent");

            modal.classList.remove("hidden");
            void content.offsetWidth; // reflow

            content.classList.remove("scale-75", "opacity-0");
            content.classList.add("scale-100", "opacity-100");
        }

        function ocultarModalReceptor() {
            const modal = document.getElementById("modalReceptor");
            const content = document.getElementById("modalContent");

            content.classList.remove("scale-100", "opacity-100");
            content.classList.add("scale-75", "opacity-0");

            setTimeout(() => {
                modal.classList.add("hidden");
            }, 300);
        }

        function renderTabla() {
            const body = document.getElementById("productosBody");
            body.innerHTML = "";
            Object.values(productos).forEach(p => {
                const imgPath = p.imageUrl ? `/images/materiales/${p.imageUrl}` : `/images/materiales/default.png`;
                body.innerHTML += `
                    <tr>
                        <td class="border px-4 py-2">x${p.count}</td>
                        <td class="border px-4 py-2"><img src="${imgPath}" class="h-12 w-12 rounded border object-cover" /></td>
                        <td class="border px-4 py-2">${p.description}</td>
                        <td class="border px-4 py-2">${p.kanban}</td>
                        <td class="border px-4 py-2">${p.partNumber}</td>
                        <td class="border px-4 py-2">${p.uom}</td>
                        <td class="border px-4 py-2">${p.stdPack}</td>
                    </tr>`;
            });
        }

        // Escaneo de empleado inicial
        document.getElementById("empleadoScan").addEventListener("keyup", function (event) {
            if (event.key === "Enter") {
                const code = this.value.trim();
                if (code !== "") {
                    fetch(`/Inventario/BuscarEmpleado?numeroDeEmpleado=${code}`)
                        .then(r => r.json())
                        .then(data => {
                            if (data.success) {
                                empleadoDespacha = data.numero;
                                flujoEstado = "escaneoKanban";
                                document.getElementById("kanbanSection").classList.remove("hidden");
                                document.getElementById("productosSection").classList.remove("hidden");
                                document.getElementById("kanbanScan").focus();
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Empleado no encontrado',
                                    text: 'Verifica el número escaneado'
                                });
                            }
                        });
                }
            }
        });

        // Escaneo de Kanban o código de cierre
        document.getElementById("kanbanScan").addEventListener("keyup", function (event) {
            if (event.key === "Enter") {
                const code = this.value.trim().toUpperCase();
                if (code !== "") {
                    if (code === "FIN") {
                        mostrarModalReceptor();
                        document.getElementById("empleadoReceptorInput").focus();
                    } else {
                        fetch(`/Inventario/GetMaterialByKanban?kanban=${code}`)
                            .then(r => r.json())
                            .then(data => {
                                if (data.success) {
                                    const material = data.material;
                                    const kanbanKey = material.kanban.trim().toUpperCase();
                                    if (productos[kanbanKey]) {
                                        productos[kanbanKey].count++;
                                    } else {
                                        productos[kanbanKey] = { ...material, count: 1 };
                                    }
                                    renderTabla();
                                } else {
                                    Swal.fire({
                                        icon: 'error',
                                        title: 'Material no encontrado',
                                        text: 'Verifica el código escaneado'
                                    });
                                }
                            });
                    }
                    this.value = "";
                }
            }
        });

        // Escaneo de empleado receptor en modal
        document.getElementById("empleadoReceptorInput").addEventListener("keyup", function (event) {
            if (event.key === "Enter") {
                const receptorCode = this.value.trim();
                if (receptorCode !== "") {
                    fetch(`/Inventario/BuscarEmpleado?numeroDeEmpleado=${receptorCode}`)
                        .then(r => r.json())
                        .then(data => {
                            if (data.success) {
                                empleadoRecibe = data.numero;
                                flujoEstado = "cierre";
                                ocultarModalReceptor();

                                // Construir DTO del pedido
                                const materiales = Object.values(productos).map(p => ({
                                    materialId: p.id,
                                    qty: p.count
                                }));

                                const pedidoDto = {
                                    responsableEntrega: empleadoDespacha,
                                    responsableReciba: empleadoRecibe,
                                    materiales: materiales
                                };

                                // Enviar pedido completo al backend
                                fetch("/Inventario/RegistrarPedido", {
                                    method: "POST",
                                    headers: { "Content-Type": "application/json" },
                                    body: JSON.stringify(pedidoDto)
                                })
                                .then(r => r.json())
                                .then(result => {
                                    if (result.success) {
                                        localStorage.setItem("registroSuccess", "true");
                                        location.reload();
                                    } else {
                                        Swal.fire({
                                            icon: 'error',
                                            title: 'Error al registrar',
                                            text: result.error || 'No se pudo registrar el pedido'
                                        });
                                    }
                                })
                                .catch(err => {
                                    Swal.fire({
                                        icon: 'error',
                                        title: 'Error de conexión',
                                        text: err.message
                                    });
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Empleado receptor no encontrado',
                                    text: 'Verifica el número escaneado'
                                });
                            }
                        });
                }
            }
        });

        // Mostrar toast después de recargar si hubo éxito
        window.addEventListener("load", function () {
            if (localStorage.getItem("registroSuccess") === "true") {
                localStorage.removeItem("registroSuccess");
                Swal.fire({
                    toast: true,
                    position: 'top-end',
                    icon: 'success',
                    title: 'Pedido registrado correctamente',
                    showConfirmButton: false,
                    timer: 3000,
                    timerProgressBar: true,
                    background: '#4CAF50',
                    color: '#fff'
                });
            }
        });
    </script>

}