@{
    ViewData["Title"] = "Listado de Materiales";
}

<!-- Contenedor principal -->
<div class="container mt-4">

    <!-- Título -->
    <div class="card rounded-pill w-25 mb-3 border-0 shadow-sm">
        <div class="card-body text-center">
            <h2 class="h5 fw-bold mb-0">📦 Listado de materiales</h2>
        </div>
    </div>
    <!-- Card contenedor de la tabla -->
    <div class="card rounded-4 border-0 shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table id="materialesTable" class="table-striped table-bordered table align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Imagen</th>
                            <th>Descripción</th>
                            <th>Kanban</th>
                            <th>Part Number</th>
                            <th>Vendor</th>
                            <th>UOM</th>
                            <th>StdPack</th>
                            <th>Costo</th>
                            <th>Categoría</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.js"></script>

    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.7/css/dataTables.bootstrap5.css" />
    <script src="https://cdn.datatables.net/2.3.7/js/dataTables.js"></script>
    <script src="https://cdn.datatables.net/2.3.7/js/dataTables.bootstrap5.js"></script>

    <script>
        $(document).ready(function () {
            $('#materialesTable').DataTable({
                ajax: '/Inventario/GetMateriales',
                responsive: true,
                columns: [
                    {
                        data: 'imageUrl',
                        render: function (data) {
                            let defaultImage = "/images/materiales/default.png";
                            let imgSrc = data && data.trim() !== "" ? data : defaultImage;
                            return `<img src="${imgSrc}" alt="Imagen" class="img-thumbnail" style="width:48px;height:48px;object-fit:cover;" />`;
                        }
                    },
                    { data: 'description' },
                    { data: 'kanban' },
                    { data: 'partNumber' },
                    { data: 'vendor' },
                    {
                        data: 'uom',
                        render: function (data) {
                            if (!data) return "";
                            let badgeClass = "bg-secondary";

                            switch (data.toUpperCase()) {
                                case "GA": badgeClass = "bg-primary"; break;
                                case "EA": badgeClass = "bg-success"; break;
                                case "KG": badgeClass = "bg-warning text-dark"; break;
                                case "LT": badgeClass = "bg-purple"; break;
                            }

                            return `<span class="badge ${badgeClass}">${data}</span>`;
                        }
                    },
                    { data: 'stdPack' },
                    { data: 'cost' },
                    { data: 'category' }
                ],
                pageLength: 10,
                language: {
                    url: "//cdn.datatables.net/plug-ins/2.3.7/i18n/es-MX.json"
                }
            });
        });
    </script>
}